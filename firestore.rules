rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to verify true tenant isolation
    // Users are authenticated with Email/Password mapping: s{storeId}_p{pin}@bby.app
    function isTenantManager(storeId) {
      return request.auth != null && 
             request.auth.token.email.matches('^s' + storeId + '_p.*@bby\\.app$');
    }

    // Function to verify if user has manager role
    function isRoleManager() {
      return request.auth != null && request.auth.token.role == 'manager';
    }

    match /stores/{storeId} {
      
      allow read: if isTenantManager(storeId);
      allow write: if isTenantManager(storeId);
      
      match /users/{userId} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId);
      }

      match /data/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId);
      }
      
      // Subcollections
      match /periods/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId);
      }
      
      match /coachingLogs/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId) && isRoleManager();
      }

      match /dailySnapshots/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId);
      }

      match /floorLeaderShifts/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId) && isRoleManager();
      }

      match /followUpTasks/{document=**} {
        allow read: if isTenantManager(storeId);
        allow write: if isTenantManager(storeId);
      }
    }
  }
}
