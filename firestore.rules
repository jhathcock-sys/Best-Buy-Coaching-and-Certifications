rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restrict access specifically to the 'stores' path
    // Since the app uses client-side credentials verified by manager PINs locally,
    // we allow read/write access to store collections to keep synchronization functional.
    match /stores/{storeId} {
      allow read, write: if true;
      
      match /{allSubPaths=**} {
        allow read, write: if true;
      }
    }
  }
}
