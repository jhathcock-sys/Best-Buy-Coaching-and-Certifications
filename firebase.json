{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/generate-coaching",
        "function": "generateCoaching"
      },
      {
        "source": "/api/audit-dialogue",
        "function": "auditDialogue"
      },
      {
        "source": "/api/verify-certification",
        "function": "verifyCertification"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
