rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // RBAC Concept for Firebase Custom Auth (Token Claims)
    // request.auth.token.role is checked.

    match /stores/{storeId} {
      
      allow read: if true;
      
      match /users/{userId} {
        // Only GMs can create/delete user accounts
        allow create, delete: if request.auth != null && request.auth.token.role == 'gm';
        allow read: if true; 
        allow update: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'gm');
      }

      match /data/deptGoals {
        allow read: if true;
        // Strict RBAC: Advisors physically blocked from modifying goals
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }
      
      match /data/metrics {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }
      
      match /data/playbookSettings {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }
      
      // Subcollections
      match /periods/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }
      
      match /coachingLogs/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor', 'advisor'];
      }

      match /dailySnapshots/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }

      match /floorLeaderShifts/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }

      match /followUpTasks/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }

      match /data/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role in ['gm', 'supervisor'];
      }
    }
  }
}
